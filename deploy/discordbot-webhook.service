[Unit]
Description=Discord Bot GitHub Webhook Listener
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/opt/discordbot
EnvironmentFile=/etc/discordbot-webhook.env
ExecStart=/usr/bin/python3 /opt/discordbot/deploy/webhook_listener.py
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
